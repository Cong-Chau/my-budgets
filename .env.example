# PostgreSQL
POSTGRES_PASSWORD=change_me

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# Gemini API keys (rotate across 5 keys)
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

# Frontend API base URL (baked in at build time)
# Use /api to proxy through nginx (recommended for Docker)
# Use https://api.yourdomain.com for external backend
VITE_API_URL=/api

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Port exposed to host (default 2604)
APP_PORT=2604
